# Copy this file to .env.local and fill in the values from your Supabase
# project: Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: enables AI mass-translation in /admin/translations.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Public site origin, used to build the Google OAuth redirect URL for /sisene.
# Locally you can leave this blank (it falls back to the request host); set it
# in production, e.g. https://materiaalitukku.com
NEXT_PUBLIC_SITE_URL=
#
# Google admin login (/sisene) also requires, in the Supabase dashboard:
#   Authentication -> Providers -> Google = enabled (Client ID + Secret from a
#   Google Cloud OAuth 2.0 client), and in that Google client's "Authorized
#   redirect URIs" add:  https://YOUR-PROJECT.supabase.co/auth/v1/callback
# Only the single admin's Google account should be given profiles.role='admin'.

# Email notifications to clients (approvals, rejections, price changes,
# registrations). Uses Resend — get a key at https://resend.com/api-keys.
# Without RESEND_API_KEY, sends are logged and skipped (app keeps working).
# EMAIL_FROM must be a verified sender/domain in Resend for production; the
# default onboarding@resend.dev works for testing.
RESEND_API_KEY=
EMAIL_FROM=

# Translation engines (admin translation tools + per-category translate).
# Default engine is Google Cloud Translation. Configure whichever you use:
GOOGLE_TRANSLATE_API_KEY=      # Google Cloud Translation v2 (default engine)
# GEMINI_API_KEY above also powers the "Gemini" engine + image verification.
ANTHROPIC_API_KEY=             # "Claude" engine
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=               # "GPT" engine
# OPENAI_MODEL=gpt-4o-mini
